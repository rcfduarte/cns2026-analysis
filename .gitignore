# Canonical .gitignore for Renato's Python repos (standardized 2026-04-16).
# Copy to <repo>/.gitignore for any new project. Extend per-repo as needed.

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
*.egg
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# Secrets — NEVER commit
.env
.env.*
!.env.example
.mcp.json
.claude/secrets/
*.key
*.pem
credentials.json
secrets/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# All data artifacts stay local — caches, the corpus, and especially the
# paywalled Springer PDFs + their extracted text (free-to-read, NOT redistributable).
data/
